{
  "name": "@anclora/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./schema": { "types": "./dist/schema.d.ts", "default": "./dist/schema.js" }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "tsx src/migrate-remote.ts",
    "db:bootstrap-admin": "tsx src/bootstrap-admin.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@anclora/core": "workspace:*",
    "@electric-sql/pglite": "^0.3.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
