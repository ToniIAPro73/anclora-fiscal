DATABASE_URL=postgresql://user:password@host/database?sslmode=require
APP_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:3001
SESSION_SECRET=replace-with-at-least-32-random-characters
# Obligatorio en producción (server.ts lanza un error si falta); cifra los
# metadatos de importación en reposo. Debe ser distinto de SESSION_SECRET.
IMPORT_METADATA_SECRET=replace-with-a-different-at-least-32-random-characters
# JSON server-only con actorId, tenantId, email, displayName, role y passwordHash scrypt.
# Los actorId/tenantId deben existir en la base para poder auditar el acceso.
AUTH_IDENTITIES_JSON=[]
SESSION_COOKIE_DOMAIN=
NEXT_PUBLIC_API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001
STORAGE_DRIVER=filesystem
STORAGE_PATH=./storage
VERIFACTU_ENABLED=false
VERIFACTU_ENVIRONMENT=sandbox
