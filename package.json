{
  "name": "anclora-fiscal",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": { "node": "22.x" },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:migrate": "pnpm --filter @anclora/db db:migrate",
    "seed": "pnpm --filter @anclora/db seed",
    "verifactu:process-due": "node scripts/process-due-verifactu.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@next/eslint-plugin-next": "15.5.18",
    "@types/node": "^22.15.30",
    "eslint": "^9.30.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
