{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "SESSION_SECRET",
    "IMPORT_METADATA_SECRET",
    "AUTH_IDENTITIES_JSON",
    "APP_ORIGIN",
    "API_INTERNAL_URL",
    "NEXT_PUBLIC_API_URL",
    "VERIFACTU_ENABLED",
    "VERIFACTU_ENVIRONMENT",
    "STORAGE_ROOT",
    "SESSION_COOKIE_DOMAIN",
    "POSTGRES_PRISMA_URL",
    "PGDATABASE",
    "POSTGRES_URL",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGUSER",
    "PGPASSWORD",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_URL_NON_POOLING",
    "DATABASE_URL_UNPOOLED",
    "POSTGRES_DATABASE",
    "NEON_PROJECT_ID",
    "POSTGRES_PASSWORD",
    "POSTGRES_HOST",
    "POSTGRES_USER"
  ],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "@anclora/web#build": { "dependsOn": ["^build"], "outputs": [".next/**", "!.next/cache/**"] },
    "@anclora/api#build": { "dependsOn": ["^build"], "outputs": ["dist/**", "api/_handler.mjs", "api/_handler.mjs.map"] },
    "lint": { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test": { "dependsOn": ["^build", "^test"], "outputs": [] },
    "test:e2e": { "dependsOn": ["^build"], "outputs": ["playwright-report/**"], "cache": false }
  }
}
