{
  "name": "@anclora/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter '@anclora/core' --filter '@anclora/db' --filter '@anclora/connectors' build && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter '@anclora/core' --filter '@anclora/db' --filter '@anclora/connectors' build && vitest run",
    "auth:hash": "bash scripts/hash-password.sh"
  },
  "dependencies": {
    "@anclora/core": "workspace:*",
    "@anclora/connectors": "workspace:*",
    "@anclora/db": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.4.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
